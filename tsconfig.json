{
  "compilerOptions": {
    "outDir": "./dist",             // Output directory
    "rootDir": "./src",             // Input directory
    "declaration": true,            // Generate type declarations
    "module": "ESNext",             // Output ES modules
    "moduleResolution": "Node",     // Use Node-style module resolution
    "target": "ES2015",             // Target modern JavaScript
    "esModuleInterop": true,        // Ensure compatibility with CommonJS
    "strict": true,                 // Enable strict type checking
    "declarationMap": true,
    "jsx": "react"
  },
  "include": ["src/index.ts", "src/lib/TranslateSheet.ts"]
}
