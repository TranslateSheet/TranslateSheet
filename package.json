{
  "name": "translate-sheet",
  "version": "0.3.18",
  "description": "translations made easy",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts --format cjs,esm --dts --out-dir dist --no-splitting --minify --no-sourcemap --target node18",
    "watch": "tsup src/index.ts src/cli/index.ts --format cjs,esm --dts --out-dir dist --no-splitting --watch",
    "prepublish": "npm version patch -m \"chore(release): %s\" && npm run build"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./cli": {
      "require": "./dist/cli/index.js"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=16.8.0",
    "i18next": "^24.0.5",
    "i18n-js": "^4.5.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.6",
    "node-fetch": "^3.3.2",
    "react": "^18.0.0",
    "react-i18next": "^15.4.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.6",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  },
  "bin": {
    "translate-sheet": "./dist/cli/index.js"
  }
}
