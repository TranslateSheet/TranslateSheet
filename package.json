{
  "name": "translate-sheet",
  "version": "0.2.29",
  "description": "translations made easy",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist",
    "prepublish": "npm version patch -m \"chore(release): %s\" && npm run build"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "i18next": "^24.0.5"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@types/node": "^22.10.1",
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  },
  "bin": {
    "translate-sheet": "./dist/cli/index.js"
  }
}
