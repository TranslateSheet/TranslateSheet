{
  "name": "translate-sheet",
  "version": "0.2.32",
  "description": "translations made easy",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsup src/index.ts src/cli/index.ts --format cjs,esm --dts --out-dir dist --no-splitting",
    "prepublish": "npm version patch -m \"chore(release): %s\" && npm run build"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "require": "./dist/cli/index.js"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=16.8.0",
    "i18next": ">=23.0.0"
  },
  "devDependencies": {
    "react": "^18.0.0",
    "@types/react": "^19.0.6"
  },
  "dependencies": {
    "@types/node": "^22.10.1",
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  },
  "bin": {
    "translate-sheet": "./dist/cli/index.js"
  }
}
